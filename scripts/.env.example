# Microsoft Graph API — MS Forms Puller
# Copy this to scripts/.env and fill in your values

AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_TENANT_ID=your-azure-tenant-id
MS_FORM_ID=your-microsoft-form-id

# For local runs: leave this blank — token is stored in scripts/.refresh_token after --init
# For GitHub Actions: set this as a repo secret instead (see GRAPH_API_SETUP.md)
MS_REFRESH_TOKEN=
